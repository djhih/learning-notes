# Copy to inventory.ini and fill in your hosts.
# baseline_targets: hosts that will run the collector (start with 3-5)
# cgroup_targets:   hosts that will receive cgroup rules (usually same set)

[baseline_targets]
# host1.example.com ansible_user=ops
# host2.example.com ansible_user=ops

[cgroup_targets]
# host1.example.com ansible_user=ops
# host2.example.com ansible_user=ops

[all:vars]
ansible_python_interpreter=/usr/bin/python3
