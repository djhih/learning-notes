    {
      "type": "timeseries",
      "title": "Swapped-out memory by command",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "VmSwap by command \u2014 who got pushed to swap by memory.high/max pressure.",
      "gridPos": {
        "x": 0,
        "y": 14,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
