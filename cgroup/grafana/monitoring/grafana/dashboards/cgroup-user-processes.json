    },
    {
      "type": "timeseries",
      "title": "Stuck (D-state) & zombie processes",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "Uninterruptible sleep = stuck on IO (dead NFS, saturated disk). Series appear only when non-zero.",
      "gridPos": {
        "x": 12,
        "y": 14,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "cgroup_process_dstate_count{service=~\"$user\"} > 0",
          "refId": "A",
          "legendFormat": "D \u00b7 {{service}} \u00b7 {{comm}}"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "cgroup_process_zombie_count{service=~\"$user\"} > 0",
