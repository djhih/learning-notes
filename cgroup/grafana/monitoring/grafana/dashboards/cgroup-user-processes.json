{
  "annotations": {
    "list": []
  },
  "description": "Per-user top processes (memory & CPU) with command line \u2014 the process-level drill-down for the cgroup dashboards. Served by exporter.py's cgroup_process_* / cgroup_top_process_* metrics. No data for a name means the user has no login session or the command is outside the exporter's top-N.",
  "editable": true,
  "graphTooltip": 0,
  "id": null,
  "links": [
    {
      "title": "Host Detail",
      "type": "link",
      "icon": "external link",
      "url": "/d/cgroup-host-detail",
      "targetBlank": false,
      "keepTime": true,
      "asDropdown": false,
      "includeVars": false,
      "tags": []
    }
  ],
  "panels": [
    {
      "type": "stat",
      "title": "Worst memory process",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "Single biggest resident-memory process across the selected user(s), right now.",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 12,
        "h": 4
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "topk(1, cgroup_top_process_memory_bytes{service=~\"$user\"})",
          "refId": "A",
          "legendFormat": "{{comm}} \u00b7 {{service}}",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "bytes",
          "decimals": 1,
          "mappings": [],
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 1073741824
              },
              {
                "color": "red",
                "value": 4294967296
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "value_and_name",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto"
      }
    },
