    {
      "type": "table",
      "title": "Top services by memory usage",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "Each cgroup service ranked by real (anon) memory in use — top row is the biggest consumer. Rows are services (cgroups), i.e. groups of processes, not individual PIDs. Extra columns: Delta anon = growing fast (culprit), refault/s = thrashing (victim), direct/s = hit its own limit, mem PSI = pain, OOM/s = already killed.",
      "gridPos": {
        "x": 0,
        "y": 5,
        "w": 24,
        "h": 10
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum by (service) (cgroup_memory_anon_bytes{instance=\"$instance\",service=~\"$service\"})",
          "refId": "A",
          "instant": true,
          "format": "table"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum by (service) (delta(cgroup_memory_anon_bytes{instance=\"$instance\",service=~\"$service\"}[15m]))",
          "refId": "B",
          "instant": true,
          "format": "table"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum by (service) (rate(cgroup_memory_workingset_refault_file_total{instance=\"$instance\",service=~\"$service\"}[5m]))",
          "refId": "C",
          "instant": true,
          "format": "table"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum by (service) (rate(cgroup_memory_pgscan_direct_total{instance=\"$instance\",service=~\"$service\"}[5m]))",
          "refId": "D",
          "instant": true,
          "format": "table"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "max by (service) (cgroup_psi_memory_some_avg10{instance=\"$instance\",service=~\"$service\"})",
          "refId": "E",
          "instant": true,
          "format": "table"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum by (service) (rate(cgroup_memory_events_oom_kill_total{instance=\"$instance\",service=~\"$service\"}[5m]))",
          "refId": "F",
          "instant": true,
          "format": "table"
        }
      ],
      "transformations": [
        {
          "id": "joinByField",
          "options": {
            "byField": "service",
            "mode": "outer"
          }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time 1": true,
              "Time 2": true,
              "Time 3": true,
              "Time 4": true,
              "Time 5": true,
              "Time 6": true,
              "Time": true
            },
            "indexByName": {
              "service": 0,
              "Value #A": 1,
              "Value #B": 2,
              "Value #C": 3,
              "Value #D": 4,
              "Value #E": 5,
              "Value #F": 6
            },
            "renameByName": {
              "service": "Service",
              "Value #A": "anon",
              "Value #B": "Δanon 15m",
              "Value #C": "refault/s",
              "Value #D": "direct/s",
              "Value #E": "mem PSI",
              "Value #F": "OOM/s"
            }
          }
        },
        {
          "id": "sortBy",
          "options": {
            "fields": {},
            "sort": [
              {
                "field": "anon",
                "desc": true
              }
            ]
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "custom": {
            "align": "auto",
            "cellOptions": {
              "type": "auto"
