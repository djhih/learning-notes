              "service": 0,
              "pid": 1,
              "comm": 2,
              "Value": 3
            },
            "renameByName": {
              "service": "User",
              "pid": "PID",
              "comm": "Process",
              "Value": "RSS"
            }
          }
        },
        {
          "id": "sortBy",
          "options": {
            "fields": {},
            "sort": [
              {
                "field": "RSS",
                "desc": true
              }
            ]
          }
        }
      ],
