      "title": "Reclaim — direct vs kswapd",
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "description": "direct = a cgroup squeezing itself (local limit). kswapd = the whole host is short on RAM (global).",
      "gridPos": {
        "x": 12,
        "y": 25,
        "w": 12,
        "h": 8
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(rate(cgroup_memory_pgscan_direct_total{instance=\"$instance\",service=~\"$service\"}[5m]))",
          "refId": "A",
          "legendFormat": "direct (hit own limit)"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "prometheus"
          },
          "expr": "sum(rate(cgroup_memory_pgscan_kswapd_total{instance=\"$instance\",service=~\"$service\"}[5m]))",
          "refId": "B",
          "legendFormat": "kswapd (whole host low)"
        }
